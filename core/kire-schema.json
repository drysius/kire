        {
            "name": "component",
            "params": [
                "path:string",
                "locals:object"
            ],
            "children": true
        },
        {
            "name": "layout",
            "children": true
        },
        {
            "name": "extends",
            "children": true
        },
        {
            "name": "section",
            "children": true
        }
