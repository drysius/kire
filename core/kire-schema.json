                "for",
                "each"
            ],
            "parents": [
                {
                    "name": "for",
                    "children": true
                },
                {
                    "name": "each",
                    "children": true
                }
            ]
        },
        {
            "name": "class",
            "params": [
                "classes:any"
            ]
        },
        {
            "name": "style",
            "params": [
                "styles:any"
            ]
        },
        {
            "name": "checked",
            "params": [
                "cond:any"
            ]
        },
        {
            "name": "selected",
            "params": [
                "cond:any"
            ]
        },
        {
            "name": "disabled",
            "params": [
                "cond:any"
            ]
        },
        {
            "name": "readonly",
            "params": [
                "cond:any"
            ]
        },
        {
            "name": "switch",
            "params": [
                "expr:any"
            ],
            "children": true
        },
        {
            "name": "case",
            "params": [
