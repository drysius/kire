{
	"compilerOptions": {
		"lib": ["ESNext", "DOM"],
		"target": "ESNext",
		"module": "esnext",
		"allowJs": true,
		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true,
		"verbatimModuleSyntax": false,
		"noEmit": true,
		"strict": true,
		"baseUrl": "./",
		"paths": {
			"@kirejs/*": ["../packages/*/src/index.ts"],
			"kire": ["../core/src/index.ts"],
			"#app/*": ["./app/*"]
		}
	}
}
