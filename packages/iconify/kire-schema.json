{
    "$schema": "https://raw.githubusercontent.com/drysius/kire/refs/heads/main/schema.json",
    "package": "@kirejs/iconify",
    "version": "0.1.2",
    "author": "Drysius",
    "repository": "https://github.com/drysius/kire",
    "dependencies": [
        "kire"
    ],
    "directives": [
        {
            "name": "icon",
            "description": "Renders an Iconify icon SVG.",
            "params": [
                "name",
                "className",
                "attrs"
            ],
            "example": "@icon('mdi:home', 'text-blue-500', { width: '24' })"
        }
    ],
    "elements": [
        {
            "name": "iconify",
            "description": "Renders an Iconify icon.",
            "void": true
        }
    ],
    "attributes": {
        "global": {}
    },
    "globals": []
}