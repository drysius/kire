{
    "$schema": "https://raw.githubusercontent.com/drysius/kire/refs/heads/main/schema.json",
    "package": "@kirejs/markdown",
    "version": "0.1.2",
    "author": "Drysius",
    "repository": "https://github.com/drysius/kire",
    "dependencies": [
        "kire",
        "marked"
    ],
    "directives": [
        {
            "name": "markdown",
            "description": "Renders Markdown content from a string or file path.",
            "params": [
                "source"
            ],
            "example": "@markdown('path/to/file.md')"
        },
        {
            "name": "mdslots",
            "description": "Loads Markdown files matching a glob pattern into a context variable.",
            "params": [
                "pattern",
                "name"
            ],
            "example": "@mdslots('posts/*.md', 'posts')"
        }
    ],
    "elements": [],
    "attributes": {
        "global": {}
    },
    "globals": []
}