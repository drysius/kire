{
	"name": "@kirejs/wire",
	"description": "Kirewire — server-driven reactive components for Kire (signals client, SSE/WebSocket transport).",
	"version": "0.2.0",
	"type": "module",
	"main": "dist/cjs/index.js",
	"module": "dist/esm/index.js",
	"types": "dist/types/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/types/index.d.ts",
			"import": "./dist/esm/index.js",
			"require": "./dist/cjs/index.js"
		},
		"./client": {
			"import": "./dist/client/index.js"
		}
	},
	"scripts": {
		"build": "bun run build.ts"
	},
	"dependencies": {
		"kire": "workspace:../../core"
	},
	"devDependencies": {
		"@types/jsdom": "^28.0.0",
		"jsdom": "^28.1.0"
	}
}
